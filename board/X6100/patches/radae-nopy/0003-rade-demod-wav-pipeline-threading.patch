+/* ---- Feature batch queue (producer-consumer pipeline) ---- */
+
+#define FQUEUE_DEPTH 4
+
+typedef struct {
+    float  *features;  /* pre-allocated, n_features_out floats */
+    int     n_out;     /* 0 = end-of-stream sentinel */
+    int     mf;        /* modem frame index */
+} FBatch;
+
+typedef struct {
+    FBatch          slots[FQUEUE_DEPTH];
+    int             head, tail, count;
+    pthread_mutex_t lock;
+    pthread_cond_t  not_full, not_empty;
+} FQueue;
+
+static void fqueue_init(FQueue *q, int n_features_out) {
+    q->head = q->tail = q->count = 0;
+    pthread_mutex_init(&q->lock, NULL);
+    pthread_cond_init(&q->not_full, NULL);
+    pthread_cond_init(&q->not_empty, NULL);
+    for (int i = 0; i < FQUEUE_DEPTH; i++)
+        q->slots[i].features = malloc((size_t)n_features_out * sizeof(float));
+}
+
+static void fqueue_push(FQueue *q, const float *features, int n_out, int mf) {
+    pthread_mutex_lock(&q->lock);
+    while (q->count == FQUEUE_DEPTH)
+        pthread_cond_wait(&q->not_full, &q->lock);
+    FBatch *s = &q->slots[q->head];
+    s->n_out  = n_out;
+    s->mf     = mf;
+    if (n_out > 0)
+        memcpy(s->features, features, (size_t)n_out * sizeof(float));
+    q->head = (q->head + 1) % FQUEUE_DEPTH;
+    q->count++;
+    pthread_cond_signal(&q->not_empty);
+    pthread_mutex_unlock(&q->lock);
+}
+
+static void fqueue_pop(FQueue *q, float *features, int *n_out, int *mf) {
+    pthread_mutex_lock(&q->lock);
+    while (q->count == 0)
+        pthread_cond_wait(&q->not_empty, &q->lock);
+    FBatch *s = &q->slots[q->tail];
+    *n_out = s->n_out;
+    *mf    = s->mf;
+    if (s->n_out > 0)
+        memcpy(features, s->features, (size_t)s->n_out * sizeof(float));
+    q->tail = (q->tail + 1) % FQUEUE_DEPTH;
+    q->count--;
+    pthread_cond_signal(&q->not_full);
+    pthread_mutex_unlock(&q->lock);
+}
+
+static void fqueue_destroy(FQueue *q) {
+    for (int i = 0; i < FQUEUE_DEPTH; i++)
+        free(q->slots[i].features);
+    pthread_mutex_destroy(&q->lock);
+    pthread_cond_destroy(&q->not_full);
+    pthread_cond_destroy(&q->not_empty);
+}
+
+/* ---- Synthesis (consumer) thread ---- */
+
+typedef struct {
+    FQueue     *queue;
+    int         n_features_out;
+    int         verbose;
+    FILE       *fout;
+    uint32_t    total_bytes;  /* written by thread, read by main after join */
+} SynthArg;
+
+static void *synth_thread(void *arg) {
+    SynthArg *a = arg;
+
+    FARGANState fargan;
+    fargan_init(&fargan);
+
+    int   fargan_ready = 0;
+    float cont_buf[5 * NB_TOTAL_FEATURES];
+    int   cont_frames  = 0;
+
+    float *feat_buf = malloc((size_t)a->n_features_out * sizeof(float));
+
+    for (;;) {
+        int n_out, mf;
+        fqueue_pop(a->queue, feat_buf, &n_out, &mf);
+        if (n_out == 0) break;  /* end-of-stream sentinel */
+
+        int n_frames = n_out / RADE_NB_TOTAL_FEATURES;
+        for (int fi = 0; fi < n_frames; fi++) {
+            float *feat = &feat_buf[fi * RADE_NB_TOTAL_FEATURES];
+
+            /* ---- fargan_cont warm-up: buffer the first 5 frames ---- */
+            if (!fargan_ready) {
+                memcpy(&cont_buf[cont_frames * RADE_NB_TOTAL_FEATURES],
+                       feat, (size_t)RADE_NB_TOTAL_FEATURES * sizeof(float));
+                if (++cont_frames >= 5) {
+                    /* fargan_cont expects features packed at stride
+                       NB_FEATURES – copy only the first NB_FEATURES of
+                       each buffered frame, matching lpcnet_demo behaviour. */
+                    float packed[5 * NB_FEATURES];
+                    for (int i = 0; i < 5; i++)
+                        memcpy(&packed[i * NB_FEATURES],
+                               &cont_buf[i * NB_TOTAL_FEATURES],
+                               (size_t)NB_FEATURES * sizeof(float));
+
+                    float zeros[FARGAN_CONT_SAMPLES];
+                    memset(zeros, 0, sizeof(zeros));
+                    fargan_cont(&fargan, zeros, packed);
+                    fargan_ready = 1;
+                }
+                continue;  /* warm-up frames are not synthesised */
+            }
+
+            /* ---- synthesise one 10-ms speech frame ---- */
+            float   fpcm[LPCNET_FRAME_SIZE];
+            int16_t pcm[LPCNET_FRAME_SIZE];
+
+            fargan_synthesize(&fargan, fpcm, feat);
+
+            /* float → int16, matching lpcnet_demo rounding */
+            for (int s = 0; s < LPCNET_FRAME_SIZE; s++) {
+                float v = fpcm[s] * 32768.0f;
+                if (v >  32767.0f)  v =  32767.0f;
+                if (v < -32767.0f)  v = -32767.0f;
+                pcm[s] = (int16_t)floor(0.5 + (double)v);
+            }
+
+            fwrite(pcm, sizeof(int16_t), (size_t)LPCNET_FRAME_SIZE, a->fout);
+            a->total_bytes += (uint32_t)(LPCNET_FRAME_SIZE * (int)sizeof(int16_t));
+        }
+    }
+
+    free(feat_buf);
+    return NULL;
+}
