--- a/cmake/BuildOpus.cmake
+++ b/cmake/BuildOpus.cmake
@@ -3,7 +3,18 @@
 set(CONFIGURE_COMMAND ./autogen.sh && ./configure --with-pic --enable-osce --enable-dred --disable-shared --disable-doc --disable-extra-programs)

 if (CMAKE_CROSSCOMPILING)
-set(CONFIGURE_COMMAND ${CONFIGURE_COMMAND} --host=${CMAKE_C_COMPILER_TARGET} --target=${CMAKE_C_COMPILER_TARGET})
+if (CMAKE_C_COMPILER_TARGET)
+    set(CONFIGURE_COMMAND ${CONFIGURE_COMMAND} --host=${CMAKE_C_COMPILER_TARGET} --target=${CMAKE_C_COMPILER_TARGET})
+else()
+    # GCC-based toolchains (e.g. Buildroot) don't set CMAKE_C_COMPILER_TARGET;
+    # derive the autoconf host triple from the compiler name instead.
+    get_filename_component(_CC_BASENAME "${CMAKE_C_COMPILER}" NAME)
+    string(REGEX REPLACE "-[^-]+$" "" _CC_PREFIX "${_CC_BASENAME}")
+    if (NOT _CC_PREFIX STREQUAL _CC_BASENAME)
+        set(CONFIGURE_COMMAND ${CONFIGURE_COMMAND} --host=${_CC_PREFIX} --target=${_CC_PREFIX})
+    endif()
+endif()
+set(CONFIGURE_COMMAND ${CONFIGURE_COMMAND} CC=${CMAKE_C_COMPILER})
 endif (CMAKE_CROSSCOMPILING)

 if (NOT DEFINED OPUS_URL)
@@ -61,9 +72,9 @@

 # Disable Opus CPU feature detection when crosscompiling for ARM due to
 # compiler issues building Windows for ARM version.
-if (CMAKE_CROSSCOMPILING AND CMAKE_SYSTEM_PROCESSOR MATCHES "aarch64")
+if (CMAKE_CROSSCOMPILING AND CMAKE_SYSTEM_PROCESSOR MATCHES "aarch64|arm")
 set(CONFIGURE_COMMAND ${CONFIGURE_COMMAND} --disable-rtcd)
-endif (CMAKE_CROSSCOMPILING AND CMAKE_SYSTEM_PROCESSOR MATCHES "aarch64")
+endif (CMAKE_CROSSCOMPILING AND CMAKE_SYSTEM_PROCESSOR MATCHES "aarch64|arm")

 ExternalProject_Add(build_opus
     BUILD_IN_SOURCE 1
@@ -84,5 +95,13 @@
     IMPORTED_IMPLIB   "${BINARY_DIR}/.libs/libopus${CMAKE_STATIC_LIBRARY_SUFFIX}"
 )

+# Opus auto-detects Ne10 NEON FFT on ARM and compiles it into libopus.a.
+# Propagate the dependency so every target linking opus also links Ne10.
+find_library(NE10_LIBRARY NAMES NE10)
+if (NE10_LIBRARY)
+    set_target_properties(opus PROPERTIES
+        INTERFACE_LINK_LIBRARIES "${NE10_LIBRARY}")
+endif ()
+
 include_directories(${SOURCE_DIR}/dnn ${SOURCE_DIR}/celt ${SOURCE_DIR}/include ${SOURCE_DIR})
 endif(APPLE AND BUILD_OSX_UNIVERSAL)
